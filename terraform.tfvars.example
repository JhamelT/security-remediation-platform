# AWS Configuration
aws_region = "us-east-1"

# Project Configuration
project_name = "security-remediation"
environment  = "dev"

# Required: Your email for SNS notifications
notification_email = "jhamelthorne@gmail.com"

# Feature Flags
enable_guardduty = true
enable_config    = false  # Phase 2
enable_inspector = false  # Phase 2

# Remediation Settings
auto_remediate_high_severity = true  # Auto-remediate severity >= 4.0

# Logging
lambda_log_retention_days = 7  # Cost optimization: 7 days for dev, 30+ for prod

# Tags
tags = {
  Project     = "SecurityRemediation"
  ManagedBy   = "Terraform"
  Owner       = "Jhamel Thorne"
  Environment = "dev"
  Purpose     = "AutomatedSecurityResponse"
}
